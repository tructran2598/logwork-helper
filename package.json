{
  "name": "logwork-helper",
  "version": "0.1.0",
  "description": "macOS Git hook, CLI, and local MCP server for logging work to Resource Optimiser.",
  "license": "UNLICENSED",
  "type": "module",
  "homepage": "https://github.com/tructran2598/logwork-helper#readme",
  "bugs": {
    "url": "https://github.com/tructran2598/logwork-helper/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tructran2598/logwork-helper.git"
  },
  "keywords": [
    "logwork",
    "resource-optimiser",
    "mcp",
    "codex",
    "cursor",
    "git-hook"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "cli.mjs",
    "config.mjs",
    "install-user.mjs",
    "install.mjs",
    "logwork-helper.mjs",
    "manual-log.mjs",
    "mcp-server.mjs",
    "setup-user.sh",
    "setup.sh",
    "hooks/",
    "lib/",
    "examples/mcp/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "logwork-helper-setup-user": "install-user.mjs",
    "logwork-helper-install": "install.mjs",
    "logwork-helper": "cli.mjs",
    "logwork-helper-manual": "manual-log.mjs",
    "logwork-helper-mcp": "mcp-server.mjs"
  },
  "scripts": {
    "setup-user": "node install-user.mjs",
    "install-hook": "node install.mjs",
    "log": "node manual-log.mjs",
    "log:dry-run": "LOGWORK_DRY_RUN=1 node manual-log.mjs",
    "start": "node logwork-helper.mjs",
    "dry-run": "LOGWORK_DRY_RUN=1 node logwork-helper.mjs",
    "test": "node --test"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
